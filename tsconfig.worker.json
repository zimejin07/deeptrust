{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist/llm",
    "rootDir": "lib/agent/llm",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "noEmit": false
  },
  "include": ["lib/agent/llm/pipeline.ts", "lib/agent/llm/worker-entry.ts"],
  "exclude": ["node_modules"]
}
